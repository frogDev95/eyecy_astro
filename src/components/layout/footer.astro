---
const contactItems = [
	{ icon: "fa-phone", label: "+1 (845) 932-4567", href: "tel:+18459324567" },
	{ icon: "fa-phone", label: "+1 (345) 333-4567", href: "tel:+13453334567" },
	{
		icon: "fa-envelope-o",
		label: "info@eyecay.ky",
		href: "mailto:info@eyecay.ky",
	},
];

const socialItems = [
	{ icon: "fa-facebook", label: "@eyecay.ky", href: "#" },
	{ icon: "fa-instagram", label: "@eyecay.ky", href: "#" },
	{ icon: "fa-times", label: "@eyecay.ky", href: "#" },
];

const quickLinks = [
	{ label: "Latest work", href: "#" },
	{ label: "Request a Quote", href: "#" },
	{ label: "Contact us", href: "#" },
];

const services = [
	"Web Design",
	"Web Development",
	"Online Marketing",
	"Search Engine",
	"Optimization",
	"Social Media Marketing",
];

const legalLinks = [
	{ label: "Cookie Policy", href: "#" },
	{ label: "TOS", href: "#" },
	{ label: "Data Processing", href: "#" },
	{ label: "Ai Usage", href: "#" },
	{ label: "Privacy Policy", href: "#" },
];
---

<footer
	class="relative overflow-hidden bg-[#020217] bg-[url('/images/footer/background_ft.avif')] bg-cover bg-center bg-no-repeat text-white py-15"
>
	<div
		class="relative mx-auto max-w-[1080px] px-6 pb-8 pt-12 sm:px-8 lg:px-0 lg:pt-16"
	>
		<div
			class="flex flex-col items-center gap-12 text-center lg:grid lg:grid-cols-[280px_minmax(0,1fr)_280px] lg:items-start lg:gap-x-10 lg:gap-y-10 lg:text-left"
		>
			<div
				class="order-2 flex w-full max-w-md flex-col items-center gap-10 lg:order-1 lg:max-w-[320px] lg:items-start max-[1200px]:pl-4"
			>
				<section
					class="flex flex-col items-center gap-5 lg:items-start"
				>
					<h3 class="text-[24px] font-semibold leading-none">
						Contact
					</h3>
					<ul class="flex flex-col items-center gap-4 lg:items-start">
						{
							contactItems.map((item) => (
								<li>
									<a
										href={item.href}
										class="inline-flex cursor-default items-center gap-1 text-[18px] font-normal text-white/95"
									>
										<span class="flex h-[26px] w-[26px] items-center justify-center rounded-full border border-white/70 text-[14px]">
											<i
												class={`fa ${item.icon}`}
												aria-hidden="true"
											/>
										</span>
										<span>{item.label}</span>
									</a>
								</li>
							))
						}
					</ul>
				</section>

				<section
					class="flex flex-col items-center gap-5 lg:items-start"
				>
					<h3 class="text-[24px] font-semibold leading-none">
						Social
					</h3>
					<ul
						class="flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap sm:justify-center lg:flex-col lg:items-start"
					>
						{
							socialItems.map((item) => (
								<li>
									<a
										href={item.href}
										class="inline-flex cursor-pointer items-center gap-1 text-[18px] font-normal text-white/95"
									>
										<span class="flex h-[26px] w-[26px] items-center justify-center rounded-full border border-white/70 text-base">
											<i
												class={`fa ${item.icon}`}
												aria-hidden="true"
											/>
										</span>
										<span>{item.label}</span>
									</a>
								</li>
							))
						}
					</ul>
				</section>
			</div>

			<div
				class="order-1 flex w-full max-w-xl flex-col items-center gap-4 lg:order-2 lg:max-w-[520px] lg:justify-self-center"
			>
				<img
					src="/images/common/mark.avif"
					alt="Eyecay mark"
					class="h-[154px] w-[127px] object-contain"
				/>

				<p
					class="cursor-pointer text-center text-[18px] font-semibold uppercase tracking-tight"
					style="font-family: 'Montserrat', Helvetica, Arial, Lucida, sans-serif;"
				>
					<span>DESIGN</span>
					<span class="px-1 text-[25px] leading-none">&bull;</span>
					<span>BRANDING</span>
					<span class="px-1 text-[25px] leading-none">&bull;</span>
					<span>MARKETING</span>
					<span class="px-1 text-[25px] leading-none">&bull;</span>
					<span>SEO</span>
				</p>

				<nav
					class="flex flex-wrap justify-center gap-3 pt-1 text-[16px] font-semibold underline underline-offset-2"
				>
					{
						quickLinks.map((item) => (
							<a href={item.href} class="cursor-pointer">
								{item.label}
							</a>
						))
					}
				</nav>

				<form class="flex sm:items-center">
					<input
						type="email"
						placeholder=""
						aria-label="Email address"
						class="h-[41px] width-[182px] flex-1 rounded-none border-0 bg-white px-4 text-black outline-none ring-0"
					/>
					<button
						type="submit"
						class="h-[43px] min-w-[144px] subscribe-btn px-6 text-[16px] font-semibold tracking-[0.12em] text-white"
					>
						Subscribe
					</button>
				</form>
			</div>

			<section
				class="order-3 flex w-full max-w-md lg:max-w-[280px] justify-center lg:justify-end lg:items-start lg:justify-self-end lg:text-left max-[1200px]:pr-4"
			>
				<div class="gap-5 flex flex-col">
					<h3 class="text-[24px] font-semibold leading-none">
						Services
					</h3>
					<ul
						class="flex flex-col items-center gap-3 text-center text-[18px] font-medium leading-[1.35] lg:items-start lg:text-left"
					>
						{
							services.map((service) => (
								<li class="max-w-[18ch] lg:max-w-none">
									<a
										href="#"
										class="inline-flex cursor-pointer"
									>
										{service}
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</section>
		</div>
	</div>
	<div
		class="mx-auto mt-14 px-2 w-full border-t border-white/12 pt-7 lg:max-w-[80%] lg:pt-8"
	>
		<div
			class="flex flex-col items-center justify-between gap-5 text-center text-[14px] font-medium leading-none text-white/90 lg:flex-row lg:items-center lg:text-left"
		>
			<p class="shrink-0">
				Copyright &copy; Eyecay 2026 All Rights Reserved.
			</p>
			<nav
				class="flex flex-wrap justify-center gap-x-3 gap-y-2 lg:justify-end"
			>
				{
					legalLinks.map((item, index) => (
						<>
							<a href={item.href} class="cursor-default">
								{item.label}
							</a>
							{index < legalLinks.length - 1 && (
								<span class="text-white/45">|</span>
							)}
						</>
					))
				}
			</nav>
		</div>
	</div>
</footer>

<style>
	.subscribe-btn {
		border-radius: 0 10px 10px 0;
		background-image: linear-gradient(
			270deg,
			#25c7fe 6px,
			#3791fd 24px,
			#407aff 35px,
			#5449fe 57px,
			#7661fe 75px,
			#8d71fe 82px,
			#8d71fe 90px
		);
	}
</style>
