---
const services = [
    {
        title: "Mobile Design",
        description:
            "Expertly blending UI/UX principles for optimal functionality on every mobile device.",
        icon: "/images/home/servicegrid/icons/mobile-design.png",
        image: "/images/home/servicegrid/mobile-design.png",
    },
    {
        title: "Website Design",
        description:
            "We seamlessly blend aesthetics and functionality, ensuring your online presence captivates and engages visitors.",
        icon: "/images/home/servicegrid/icons/website-design.png",
        image: "/images/home/servicegrid/website-design.png",
    },
    {
        title: "Social Media",
        description:
            "We create meaningful connections and expand your brand's online community.",
        icon: "/images/home/servicegrid/icons/digital-marketing.png",
        image: "/images/home/servicegrid/digital-marketing.png",
    },
    {
        title: "Website Development",
        description:
            "We go beyond generic themes, crafting unique websites tailored to your brand, ensuring a distinctive and engaging digital footprint.",
        icon: "/images/home/servicegrid/icons/web-development.png",
        image: "/images/home/servicegrid/web-development.png",
    },
    {
        title: "Web Hosting",
        description:
            "Reliable and scalable hosting, ensuring optimal performance, security, and seamless user experiences for your website visitors.",
        icon: "/images/home/servicegrid/icons/web-hosting.png",
        image: "/images/home/servicegrid/web-hosting.png",
    },
    {
        title: "SEO",
        description:
            "Elevate your online visibility with our SEO strategies, ensuring that your brand shines prominently in search engine results.",
        icon: "/images/home/servicegrid/icons/seo.png",
        image: "/images/home/servicegrid/seo.png",
    },
];
---

<section class="services-grid" aria-labelledby="services-grid-title">
    <div class="services-grid__inner">
        <header class="services-grid__header">
            <p class="services-grid__eyebrow">What We Do</p>
            <h2 id="services-grid-title">Our Services</h2>
        </header>

        <div class="services-grid__list">
            {
                services.map((service) => (
                    <article class="service-card">
                        <div class="service-card__body">
                            <div class="service-card__icon" aria-hidden="true">
                                <img src={service.icon} alt="" loading="lazy" />
                            </div>
                            <h3 class="mt-5">{service.title}</h3>
                            <p>{service.description}</p>
                        </div>
                        <div class="service-card__hover">
                            <div class="service-card__hover-head">
                                <div class="service-card__hover-copy">
                                    <div
                                        class="service-card__icon"
                                        aria-hidden="true"
                                    >
                                        <img
                                            src={service.icon}
                                            alt=""
                                            loading="lazy"
                                        />
                                    </div>
                                    <h3>{service.title}</h3>
                                </div>
                                <span
                                    class="service-card__hover-arrow"
                                    aria-hidden="true"
                                >
                                    <img src="/images/home/servicegrid/icons/right-icon.png" />
                                </span>
                            </div>
                            <div class="service-card__hover-media">
                                <img
                                    src={service.image}
                                    alt=""
                                    loading="lazy"
                                />
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .services-grid {
        position: relative;
        overflow: hidden;
        margin: auto;
        margin-top: 150px;
        padding-bottom: 50px;
        background-image: url("/images/home/servicegrid/servicegrid_bg.png");
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
    }
    .services-grid__inner {
        margin: 0 auto;
        position: relative;
        z-index: 1;
        padding: 3% 0px;
        width: 80%;
        margin: auto;
    }
    .services-grid__header {
        text-align: center;
        margin-bottom: 87px;
    }
    .services-grid__eyebrow {
        width: fit-content;
        margin: auto;
        color: #333;
        font-family: Montserrat, sans-serif;
        font-size: clamp(1rem, 0.75rem + 0.8vw, 1.45rem);
        font-weight: 800;
        line-height: 1.2;
        text-transform: uppercase;
        background-image: linear-gradient(
            90deg,
            #8d71fe 6px,
            #7661fe 23px,
            #4d53fe 45px,
            #3f7cfe 57px,
            #349dfb 71px,
            #28c2ff 85px
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        padding-bottom: 10px;
        font-family: "Montserrat", Helvetica, Arial, Lucida, sans-serif;
        font-weight: 800;
        font-size: 21px;
        text-align: center;
    }
    .services-grid__header h2 {
        font-family: "Jost", Helvetica, Arial, Lucida, sans-serif;
        font-weight: 700;
        font-size: 48px;
        color: #ffffff !important;
        line-height: 60px;
        text-align: center;
        margin-top: 0px;
        text-transform: uppercase;
    }
    .services-grid__list {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-around;
        gap: 20px;
    }
    .service-card {
        position: relative;
        min-height: 284px;
        width: calc(33.333% - 14px);
    }
    .service-card__body {
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        background-color: #131928;
        padding: 35px 30px 30px 30px;
        z-index: 1;
    }
    .service-card__body.np {
        padding: 0px;
    }
    .service-card__hover {
        position: absolute;
        inset: 0;
        display: grid;
        grid-template-rows: 88px 1fr;
        background: #131928;
        box-sizing: border-box;
        transform: scale3d(1, 0.7, 1);
        transform-origin: 50% 0%;
        backface-visibility: hidden;
        will-change: transform, opacity;
        opacity: 0;
        transition:
            transform 0.3s ease,
            opacity 0.3s ease;
        z-index: 2;
        visibility: hidden;
    }
    .service-card:hover .service-card__hover {
        transform: scale3d(1, 1, 1);
        opacity: 1;
        visibility: visible;
    }
    .service-card__body h3,
    .service-card__hover-copy h3 {
        margin: 20px 0 0;
        color: #fff;
        font-family: Jost;
        font-size: 26px;
        font-style: normal;
        font-weight: 600;
        line-height: normal;
        margin-bottom: 0;
        text-align: start;
    }
    .service-card__hover-copy h3 {
        letter-spacing: 0.52px;
    }
    .service-card__hover-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 84px;
        align-items: stretch;
        background: #212947;
    }
    .service-card__hover-copy {
        display: flex;
        align-items: center;
        gap: 1.1rem;
        padding-left: 30px;
    }
    .service-card__hover-copy h3 {
        margin: 0;
    }
    .service-card__hover-arrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(21deg, #495bff 25%, #55e6a5 100%);
    }
    .service-card__hover-head:hover .service-card__hover-arrow {
        background: linear-gradient(200deg, #495bff 25%, #55e6a5 100%);
    }

    .service-card__hover-media {
        overflow: hidden;
        background: linear-gradient(180deg, #101a35 0%, #0c1325 100%);
    }
    .service-card__hover-media img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
    }
    .service-card:after {
        position: absolute;
        content: "";
        width: 100%;
        height: 100%;
        border: 1px solid #1f1f36;
        background-color: #fff0;
        left: 10px;
        top: 10px;
        z-index: -1;
        transition: 0.3s;
    }
    .service-card__body p {
        margin-top: 25px;
        position: relative;
        color: #fff;
        font-family: Jost;
        font-size: 16px;
        font-style: normal;
        font-weight: 400;
        line-height: 1.55;
        margin-bottom: 0;
        max-width: 360px;
    }
</style>
