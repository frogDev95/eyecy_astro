<style>
    .animation-part {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 500px !important;
        transform: scale(1.6) translateY(26px);
        background: transparent;
        mix-blend-mode: screen;
    }
    .animation-part svg {
        display: block;
        background: transparent;
    }
    .hero-decor {
        position: absolute;
        position: absolute !important;
        text-align: center;
        transform: rotate(20deg);
        --decor-duration: 7s;
        animation: decor-move var(--decor-duration) linear infinite;
    }
    .decor-plus--one {
        top: -26px;
        left: -36px;
        bottom: auto;
        right: auto;
        --decor-duration: 9s;
    }
    .decor-plus--two {
        top: -110px;
        left: 50%;
        bottom: auto;
        right: auto;
        --decor-duration: 5s;
        transform: translateX(-50%);
    }
    .decor-plus--three {
        top: -80px;
        bottom: auto;
        right: 80px;
        left: auto;
    }
    .decor-plus--four {
        bottom: 0;
        top: auto;
        left: -170px;
        right: auto;
        --decor-duration: 6s;
    }
    .decor-ring {
        top: 50%;
        bottom: auto;
        left: 0;
        right: auto;
        transform: translateY(-50%);
    }
    .decor-zigzag--one {
        top: 50%;
        bottom: auto;
        right: 0;
        left: auto;
        transform: translateY(-50%);
        --decor-duration: 6s;
    }
    .decor-zigzag--two {
        bottom: -50px;
        top: auto;
        left: 50px;
        right: auto;
        --decor-duration: 8s;
    }
    @keyframes decor-move {
        0% {
            transform: translate(0) rotate(0deg);
        }
        25% {
            transform: translate(-10px, 10px) rotate(10deg);
        }
        50% {
            transform: translate(5px, -5px) rotate(25deg);
        }
        75% {
            transform: translate(15px, -5px) rotate(15deg);
        }
        100% {
            transform: translate(0) rotate(0deg);
        }
    }
    @media screen and (max-width: 985px) {
        .animation-part {
            transform: scale(0.9) translateY(-10px);
        }
    }
</style>
