---
const projects = [
    {
        title: "Glamorous",
        image: "/images/home/recentBlog/https___glamorous.avif",
        href: "/portfolio/",
    },
    {
        title: "Pirates Fest Cayman",
        image: "/images/home/recentBlog/https___piratesfestcayman.avif",
        href: "/portfolio/",
    },
    {
        title: "Parliament",
        image: "/images/home/recentBlog/https___parliament.avif",
        href: "/portfolio/",
    },
    {
        title: "Morgan's Cayman",
        image: "/images/home/recentBlog/https___morganscayman.avif",
        href: "/portfolio/",
    },
];

const repeatedProjects = Array.from({ length: 12 }, (_, index) => ({
    ...projects[index % projects.length],
    loopIndex: index,
}));
---

<section
    class="recent-blog-posts"
    aria-labelledby="recent-blog-posts-title"
    data-recent-blog-posts
>
    <div class="recent-blog-posts__inner">
        <header class="recent-blog-posts__header">
            <p class="recent-blog-posts__eyebrow">PORTFOLIO</p>
            <h2 id="recent-blog-posts-title">OUR LATEST WORK</h2>
        </header>

        <div class="recent-blog-posts__stage" data-carousel-stage>
            <div class="recent-blog-posts__track" data-carousel-track>
                {
                    repeatedProjects.map((project) => (
                        <article
                            class="recent-blog-posts__card"
                            data-card
                            data-loop-index={project.loopIndex}
                        >
                            <a
                                class="recent-blog-posts__card-link"
                                href={project.href}
                                aria-label={`View ${project.title} project`}
                            >
                                <img
                                    class="recent-blog-posts__card-image"
                                    src={project.image}
                                    alt={project.title}
                                    loading="lazy"
                                />
                            </a>
                        </article>
                    ))
                }
            </div>
        </div>

        <div class="recent-blog-posts__controls">
            <button
                class="recent-blog-posts__control"
                type="button"
                data-direction="prev"
                aria-label="Show previous project"
            >
                <svg
                    width="40"
                    height="20"
                    viewBox="0 0 40 20"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <line x1="38" y1="10" x2="8" y2="10"></line>
                    <polyline points="15,2 7,10 15,18" fill="none"></polyline>
                </svg>
            </button>
            <button
                class="recent-blog-posts__control"
                type="button"
                data-direction="next"
                aria-label="Show next project"
            >
                <svg
                    width="40"
                    height="20"
                    viewBox="0 0 40 20"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <line x1="2" y1="10" x2="32" y2="10"></line>
                    <polyline points="25,2 33,10 25,18" fill="none"></polyline>
                </svg>
            </button>
        </div>
    </div>
</section>

<script>
    const carousel = document.querySelector("[data-recent-blog-posts]");

    if (carousel) {
        const track = carousel.querySelector("[data-carousel-track]");
        const cards = Array.from(carousel.querySelectorAll("[data-card]"));
        const controls = Array.from(
            carousel.querySelectorAll("[data-direction]"),
        );
        const compactQuery = window.matchMedia("(max-width: 985px)");
        const projectCount = 4;

        let activeIndex = projectCount;
        let autoSlideId;
        let isAnimating = false;

        const setInitialHiddenState = () => {
            cards.forEach((card) => {
                card.classList.remove(
                    "is-center",
                    "is-left",
                    "is-right",
                    "is-outer-left",
                    "is-outer-right",
                );
                card.classList.add("is-hidden");
            });
        };

        const assignPositions = () => {
            cards.forEach((card, index) => {
                const offset = index - activeIndex;
                card.classList.remove(
                    "is-center",
                    "is-left",
                    "is-right",
                    "is-outer-left",
                    "is-outer-right",
                    "is-hidden",
                );

                if (compactQuery.matches) {
                    card.classList.add(
                        offset === 0 ? "is-center" : "is-hidden",
                    );
                    return;
                }

                if (offset === 0) {
                    card.classList.add("is-center");
                    return;
                }

                if (offset === -1) {
                    card.classList.add("is-left");
                    return;
                }

                if (offset === 1) {
                    card.classList.add("is-right");
                    return;
                }

                if (offset === -2) {
                    card.classList.add("is-outer-left");
                    return;
                }

                if (offset === 2) {
                    card.classList.add("is-outer-right");
                    return;
                }

                card.classList.add("is-hidden");
            });
        };

        const resetLoopIfNeeded = () => {
            let nextIndex = activeIndex;

            if (activeIndex >= cards.length - 3) {
                nextIndex -= projectCount;
            } else if (activeIndex <= 2) {
                nextIndex += projectCount;
            }

            if (nextIndex === activeIndex) return;

            activeIndex = nextIndex;
            track.classList.add("is-resetting");
            assignPositions();
            void track.offsetHeight;
            track.classList.remove("is-resetting");
        };

        const move = (direction) => {
            if (isAnimating) return;

            isAnimating = true;
            activeIndex += direction === "next" ? 1 : -1;
            assignPositions();

            window.setTimeout(() => {
                resetLoopIfNeeded();
                isAnimating = false;
            }, 760);
        };

        const startAutoSlide = () => {
            window.clearInterval(autoSlideId);
            autoSlideId = window.setInterval(() => move("next"), 3000);
        };

        controls.forEach((control) => {
            control.addEventListener("click", () => {
                move(control.getAttribute("data-direction") || "next");
                startAutoSlide();
            });
        });

        compactQuery.addEventListener("change", () => {
            track.classList.add("is-resetting");
            assignPositions();
            void track.offsetHeight;
            track.classList.remove("is-resetting");
        });

        setInitialHiddenState();

        window.requestAnimationFrame(() => {
            window.requestAnimationFrame(() => {
                assignPositions();
                startAutoSlide();
            });
        });

        document.addEventListener(
            "astro:before-swap",
            () => {
                window.clearInterval(autoSlideId);
            },
            { once: true },
        );
    }
</script>

<style>
    .recent-blog-posts {
        --carousel-header-width: min(80rem, calc(100vw - 2rem));
        --carousel-stage-height: clamp(16rem, 42vw, 41rem);
        --carousel-center-width: clamp(20rem, 44vw, 52rem);
        --carousel-side-width: clamp(17rem, 36vw, 42rem);
        --carousel-outer-width: clamp(12rem, 27vw, 31rem);
        --carousel-side-offset: clamp(13rem, 24vw, 31rem);
        --carousel-outer-offset: clamp(26rem, 47vw, 64rem);
        --carousel-shift-step: clamp(4rem, 8vw, 8rem);
        --carousel-control-size: 50px;
        --carousel-control-font: clamp(1.25rem, 1.8vw, 1.85rem);
        --carousel-controls-width: min(92vw, 116rem);
        --carousel-duration: 0.76s;
        --carousel-ease: cubic-bezier(0.16, 1, 0.3, 1);
        background: #131928;
        overflow: hidden;
        padding: clamp(2.5rem, 4vw, 3rem) 0 clamp(3.5rem, 5vw, 4.75rem);
    }

    .recent-blog-posts__inner {
        width: 100%;
        margin: 0 auto;
    }

    .recent-blog-posts__header {
        width: var(--carousel-header-width);
        margin: 0 auto;
        text-align: center;
    }

    .recent-blog-posts__eyebrow {
        margin: 0 0 clamp(0.5rem, 1vw, 0.625rem);
        font-family: "Montserrat", Helvetica, Arial, Lucida, sans-serif;
        font-size: clamp(1rem, 1.2vw, 1.3125rem);
        font-weight: 800;
        line-height: 1;
        text-transform: uppercase;
        background: linear-gradient(
            90deg,
            #8d71fe 6px,
            #7661fe 23px,
            #4d53fe 45px,
            #3f7cfe 57px,
            #349dfb 71px,
            #28c2ff 85px
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
    }

    .recent-blog-posts__header h2 {
        margin: 0;
        font-family: "Jost", Helvetica, Arial, Lucida, sans-serif;
        font-weight: 700;
        font-size: clamp(2rem, 3.4vw, 3rem);
        line-height: clamp(2.5rem, 4.2vw, 3.75rem);
        color: #ffffff !important;
        text-shadow:
            1.5px 0 0 rgba(255, 129, 169, 0.88),
            -1.5px 0 0 rgba(54, 192, 255, 0.88);
    }

    .recent-blog-posts__stage {
        position: relative;
        margin-top: clamp(2rem, 4vw, 3.25rem);
        width: 100vw;
        min-height: var(--carousel-stage-height);
        overflow: hidden;
    }

    .recent-blog-posts__track {
        position: relative;
        width: 100vw;
        min-height: var(--carousel-stage-height);
        margin-left: 50%;
        transform: translateX(-50%);
    }

    .recent-blog-posts__track.is-resetting .recent-blog-posts__card {
        transition: none;
    }

    .recent-blog-posts__card {
        position: absolute;
        top: 50%;
        left: 50%;
        overflow: hidden;
        border-radius: clamp(1rem, 1.6vw, 1.375rem);
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid transparent;
        box-shadow: 0 clamp(1rem, 1.8vw, 1.625rem) clamp(2.25rem, 4vw, 4.375rem)
            rgba(0, 0, 0, 0.24);
        will-change: transform, opacity, filter;
        transition:
            transform var(--carousel-duration) var(--carousel-ease),
            opacity var(--carousel-duration) var(--carousel-ease),
            filter var(--carousel-duration) var(--carousel-ease),
            box-shadow var(--carousel-duration) var(--carousel-ease);
        visibility: hidden;
    }

    .recent-blog-posts__card.is-center {
        z-index: 5;
        width: var(--carousel-center-width);
        opacity: 1;
        filter: brightness(1) saturate(1);
        transform: translate(-50%, -50%) scale(1);
        visibility: visible;
        border-color: rgba(83, 255, 228, 0.2);
        box-shadow:
            0 0 0 1px rgba(56, 255, 214, 0.08),
            0 0 clamp(1.4rem, 2.4vw, 2.8rem) rgba(47, 223, 180, 0.18),
            0 clamp(1.6rem, 2.8vw, 2.6rem) clamp(3.2rem, 5.4vw, 5.8rem)
                rgba(0, 0, 0, 0.36);
    }

    .recent-blog-posts__card.is-left {
        z-index: 4;
        width: var(--carousel-side-width);
        opacity: 0.92;
        filter: brightness(0.92);
        visibility: visible;
        transform: translate(calc(-50% - var(--carousel-side-offset)), -50%)
            scale(0.96);
    }

    .recent-blog-posts__card.is-right {
        z-index: 4;
        width: var(--carousel-side-width);
        opacity: 0.96;
        filter: brightness(0.96);
        visibility: visible;
        transform: translate(calc(-50% + var(--carousel-side-offset)), -50%)
            scale(0.96);
    }

    .recent-blog-posts__card.is-outer-left {
        z-index: 2;
        width: var(--carousel-outer-width);
        opacity: 0.46;
        filter: brightness(0.72) saturate(0.85);
        visibility: visible;
        transform: translate(calc(-50% - var(--carousel-outer-offset)), -50%)
            scale(0.92);
    }

    .recent-blog-posts__card.is-outer-right {
        z-index: 3;
        width: var(--carousel-outer-width);
        opacity: 0.72;
        filter: brightness(0.82) saturate(0.9);
        visibility: visible;
        transform: translate(calc(-50% + var(--carousel-outer-offset)), -50%)
            scale(0.92);
    }

    .recent-blog-posts__card.is-hidden {
        z-index: 1;
        opacity: 0;
        pointer-events: none;
        visibility: hidden;
        filter: blur(2px);
        transform: translate(
                calc(
                    -50% + var(--carousel-outer-offset) +
                        var(--carousel-shift-step)
                ),
                -50%
            )
            scale(0.92);
    }

    @media (max-width: 985px) {
        .recent-blog-posts {
            --carousel-header-width: calc(100vw - 2rem);
            --carousel-stage-height: clamp(15rem, 58vw, 28rem);
            --carousel-center-width: calc(100vw - 2.5rem);
            --carousel-controls-width: calc(100vw - 2rem);
        }

        .recent-blog-posts__card.is-center {
            width: var(--carousel-center-width);
            border-radius: clamp(0.9rem, 1.4vw, 1.25rem);
            transform: translate(-50%, -50%) scale(1);
        }

        .recent-blog-posts__card.is-hidden {
            transform: translate(-50%, -50%) scale(0.88);
        }
    }

    .recent-blog-posts__card-link {
        display: block;
        line-height: 0;
    }

    .recent-blog-posts__card-image {
        display: block;
        width: 100%;
        aspect-ratio: 1.35 / 1;
        object-fit: cover;
    }

    .recent-blog-posts__controls {
        width: 55%;
        margin: 0 auto 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .recent-blog-posts__control {
        width: var(--carousel-control-size);
        height: var(--carousel-control-size);
        border-radius: 999px;
        border: 2.355px solid #888A90;
        background: transparent;
        color: #dfe3f4;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: var(--carousel-control-font);
        line-height: 1;
        cursor: pointer;
        padding: 0;
        transition:
            transform 0.25s ease,
            color 0.25s ease,
            box-shadow 0.25s ease;
    }

    .recent-blog-posts__control {
        position: relative;
    }
    .recent-blog-posts__control svg {
        position: absolute;
        stroke-width: 3px;
        stroke: #888A90;
    }
    .recent-blog-posts__control:first-child svg{
        left: 15px;
    }
    .recent-blog-posts__control:nth-child(2) svg {
        right: 15px;
    }

    .recent-blog-posts__control:hover {
        transform: scale(1.08);
        color: #ffffff;
        box-shadow: 0 0 18px rgba(255, 255, 255, 0.12);
    }

    @media (max-width: 985px) {
        .recent-blog-posts__controls {
            margin-top: 30px;
        }
    }
</style>
