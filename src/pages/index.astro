---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Home/Hero.astro";
import ClientLogos from "../components/Home/ClientLogos.astro";
import ServicesGrid from "../components/Home/ServicesGrid.astro";
import AgencyIntro from "../components/Home/AgencyIntro.astro";
import SeoServices from "../components/Home/SeoServices.astro";
import PortfolioShowcase from "../components/Home/PortfolioShowcase.astro";
import RecentBlogPosts from "../components/Home/RecentBlogPosts.astro";
import CtaStrip from "../components/Home/CtaStrip.astro";
---

<div class="home">
	<Layout>
		<Hero />
		<ClientLogos />
		<ServicesGrid />
		<AgencyIntro />
		<SeoServices />
		<PortfolioShowcase />
		<RecentBlogPosts />
		<CtaStrip />
	</Layout>
</div>

<style>
	.home {
		background-color: #070d1d !important;
	}
</style>
